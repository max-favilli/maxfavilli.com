---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostListItem from "../../components/PostListItem.astro";
import { NAV_SECTIONS } from "../../consts";
import {
  getLatestPostByCategory,
  getPostsByCategory,
  getPublishedPosts,
  slugifyCategory
} from "../../lib/content";
import { buildSeo } from "../../lib/seo";

export async function getStaticPaths() {
  return NAV_SECTIONS.map((category) => ({
    params: { category: slugifyCategory(category) },
    props: { category }
  }));
}

const { category } = Astro.props;
const posts = await getPublishedPosts();
const latestByCategory = getLatestPostByCategory(posts);
const postsByCategory = getPostsByCategory(posts);
const categoryPosts = postsByCategory[category] ?? [];
const seo = buildSeo({
  title: category,
  description: `Posts about ${category.toLowerCase()} by Max Favilli.`
});
---
<BaseLayout seo={seo} latestByCategory={latestByCategory}>
  <section>
    <div class="archive-head">
      <p class="eyebrow">Category</p>
      <h1 class="archive-title">{category}</h1>
      <p class="archive-intro">
        {categoryPosts.length} {categoryPosts.length === 1 ? "post" : "posts"} in this section.
      </p>
    </div>
    <div class="post-stream">
      {categoryPosts.map((post) => (
        <PostListItem post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
